Fedora base template configuration (full/xfce version)
Version and repo are configurable in config.jinja (cfg.qvm.fedora).
#}

{% from 'config.jinja' import cfg with context -%}
{% set base = 'fedora' -%}
{% set version = cfg.qvm.fedora.get('version', '43') -%}
{% set flavor = '' -%}
{% set repo = cfg.qvm.fedora.get('repo', 'qubes-templates-itl') -%}
{% if flavor -%}
  {% set flavor = '-' ~ flavor -%}
{% endif -%}
{% set template = base ~ '-' ~ version ~ flavor -%}
{% set template_clean = base ~ flavor -%}
