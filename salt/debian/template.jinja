Debian base template configuration
Version and repo are configurable in config.jinja (cfg.qvm.debian).
#}

{% from 'config.jinja' import cfg with context -%}
{% set base = 'debian' -%}
{% set version = cfg.qvm.debian.get('version', '13') -%}
{% set flavor = '' -%}
{% set repo = cfg.qvm.debian.get('repo', 'qubes-templates-itl') -%}
{% if flavor -%}
  {% set flavor = '-' ~ flavor -%}
{% endif -%}
{% set template = base ~ '-' ~ version ~ flavor -%}
{% set template_clean = base ~ flavor -%}
