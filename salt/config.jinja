    "console_binary_sha256": "9ad55a37b290140bf907750f3f8f572a724f8e791f07e3cf0988c3329770217d",

    "enabled": True,
    "template_source": "debian-minimal",
    "template": "tpl-qubesair",
    "qube": "qubesair-console",
    "label": "orange",
    # sys-firewall, not sys-tailscale: no sys-tailscale exists on this machine
    # (mgmt.tailscale is not deployed), and create.sls would set a netvm that is
    # not there. Everything the console needs — the PVE API through the ingress,
    # the artifact store, the remote qubes it provisions — is on 10.31.0.0/24 and
    # reachable through sys-firewall. Switch back after deploying mgmt.tailscale
