    "database_dsn": "/rw/config/qubesair/qubes-air.db",
    {#- Ships FALSE so a first apply reaches a RUNNING console.

        Enabling it makes the preflight require a populated terraform root, and
        nothing in this module populates one — the roots live in the qubes-air
        repo and need `terraform init` against the provider mirror. A fresh
        deploy with this set True therefore fails at ExecStartPre every time,
        which reads as "the states are broken" rather than "one manual step is
        outstanding".

        To turn provisioning on, see README "Enabling orchestration": copy the
        terraform root into data_dir/terraform, run terraform init there, then
        flip this and re-apply qubesair.console. -#}
    "orchestrator_enabled": False,
    "terraform_dir": "/rw/config/qubesair/terraform",
    "terraform_var_file": "/rw/config/qubesair/terraform/environments/infra.tfvars",
    "terraform_generated_var_file": "generated/qubes.tfvars.json",
