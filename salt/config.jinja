  "remotevm": {
    "relay": "mgmt-jump",
    "transport_rpc": "qubesair.SSHProxy",
    "targets": [
    ],
    "allowed_sources": ["@anyvm"],
    "services": [
    ],
    "grpc": {
      "enabled": False,
      "remote_endpoint": "",
      "client_bin": "/usr/local/bin/qubesair-relay-client",
      "cert_file": "/rw/config/qubesair/relay.crt",
      "key_file": "/rw/config/qubesair/relay.key",
      "ca_file": "/rw/config/qubesair/ca.crt",
      "vault_certs": False,
      "vault_qube": "vault-cloud",
      "vault_cert_name": "relay-cert",
      "vault_key_name": "relay-key",
      "vault_ca_name": "relay-ca",
      "reverse_local_target": "vault-cloud",
      "keepalive_seconds": 20,
